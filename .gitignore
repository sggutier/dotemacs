# Machine-specific custom variables written by M-x customize.
# Our committed baseline lives in customs-defaults.el instead.
customs.el

# Work-specific modules.  Clone your internal repo here on work machines:
#   git clone <internal-url> modules/work
modules/work/

# Local overrides (work-machine settings, private URLs, etc.)
local.el

# Elpaca-managed package builds and repos — not source-controlled
elpaca/

# Compiled Lisp and native-compilation cache
eln-cache/

# Runtime state files auto-generated by Emacs
auto-save/
auto-save-list/
recentf
tramp
persp-auto-save/
persp-confs/

# Tree-sitter grammar binaries (rebuilt on first use)
tree-sitter/
